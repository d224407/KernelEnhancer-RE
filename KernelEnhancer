#!/system/bin/sh
#==============================================================================
# KernelEnhancer Script - Được dịch từ mã nguồn pseudo-C (32-bit & 64-bit)
#==============================================================================

MODDIR="/data/adb/modules/KernelEnhancer"
LOG_TMP="/data/local/tmp/KernelEnhancer.log"
LOG_SDCARD="/sdcard/KernelEnhancer.log"

# Hàm ghi log song song vào hệ thống và bộ nhớ trong
log_print() {
    local msg="$1"
    local timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    echo "[$timestamp] $msg" >> "$LOG_TMP"
    if [ -d "/sdcard" ]; then
        echo "[$timestamp] $msg" >> "$LOG_SDCARD"
    fi
}

# Hàm ghi giá trị vào các phân hệ sysfs/procfs một cách an toàn
write_val() {
    local val="$1"
    local node="$2"
    if [ -f "$node" ] && [ -w "$node" ]; then
        echo "$val" > "$node" 2>/dev/null
        return 0
    fi
    return 1
}

# 1. KIỂM TRA TÍNH TOÀN VẸN (Integrity Check)
if [ ! -f "$MODDIR/module.prop" ]; then
    exit 1
fi

# Chuỗi Hash SHA256 gốc từ file C để check mã độc hoặc chỉnh sửa trái phép
REQUIRED_SHA256="8308851d80c11311b33006ad3615d3cbfecb71e591572f045d3bc61df6e60025"
CURRENT_SHA256=$(sha256sum "$MODDIR/module.prop" 2>/dev/null | awk '{print $1}')

if [ -z "$CURRENT_SHA256" ]; then
    # Thử lại bằng busybox của Magisk nếu sha256sum mặc định lỗi
    CURRENT_SHA256=$(/data/adb/magisk/busybox sha256sum "$MODDIR/module.prop" 2>/dev/null | awk '{print $1}')
fi

if [ "$CURRENT_SHA256" != "$REQUIRED_SHA256" ]; then
    exit 1
fi

# 2. ĐỢI HỆ THỐNG KHỞI ĐỘNG XONG (Boot Verification)
# Vòng lặp tối đa 30 lần (60 giây) đợi sys.boot_completed = 1
boot_count=0
while [ "$boot_count" -lt 30 ]; do
    if [ "$(getprop sys.boot_completed 2>/dev/null)" = "1" ]; then
        break
    fi
    sleep 2
    boot_count=$((boot_count + 1))
done

# Vòng lặp tối đa 20 lần (40 giây) đợi Boot Animation dừng hẳn
anim_count=0
while [ "$anim_count" -lt 20 ]; do
    if [ "$(getprop init.svc.bootanim 2>/dev/null)" = "stopped" ]; then
        break
    fi
    sleep 2
    anim_count=$((anim_count + 1))
done

sleep 8

# Khởi tạo lại file Log rỗng
:> "$LOG_TMP"
if [ -d "/sdcard" ]; then
    :> "$LOG_SDCARD"
fi

log_print "KernelEnhancer Started"

# 3. ÉP CÁC LÕI CPU LUÔN ONLINE (CPU Online Tweak)
cpu_changed=false
for cpu_online in /sys/devices/system/cpu/cpu*/online; do
    if [ -f "$cpu_online" ] && [ "$(cat "$cpu_online")" = "0" ]; then
        if write_val "1" "$cpu_online"; then
            cpu_changed=true
        fi
    fi
done
if [ "$cpu_changed" = true ]; then
    log_print "CPU Online"
fi

# 4. TỰ ĐỘNG ĐO LƯỢNG RAM ĐỂ PHÂN PHỐI THÔNG SỐ (RAM Detection)
mem_total_kb=$(awk '/MemTotal:/ {print $2}' /proc/meminfo)
if [ -n "$mem_total_kb" ]; then
    mem_total_mb=$((mem_total_kb / 1024))
else
    mem_total_mb=0
fi

# Cấu hình mặc định dành cho thiết bị RAM >= 4GB
vfs_cache_pressure=40
dirty_ratio=120
page_cluster=3

# Điều chỉnh nếu thiết bị cấu hình RAM thấp (< 4GB / 4096MB)
if [ "$mem_total_mb" -gt 0 ] && [ "$mem_total_mb" -le 4096 ]; then
    dirty_ratio=149  # Tương đương 0x95 trong mã C
    page_cluster=5
fi

# 5. TỐI ƯU HÓA BỘ NHỚ ẢO (Virtual Memory Tweaks)
vm_changed=false
if write_val "850" "/proc/sys/vm/dirty_writeback_centisecs"; then vm_changed=true; fi
if write_val "$page_cluster" "/proc/sys/vm/page-cluster"; then vm_changed=true; fi
if write_val "$vfs_cache_pressure" "/proc/sys/vm/vfs_cache_pressure"; then vm_changed=true; fi
if write_val "21" "/proc/sys/vm/stat_interval"; then vm_changed=true; fi
if write_val "$dirty_ratio" "/proc/sys/vm/dirty_ratio"; then vm_changed=true; fi

if [ "$vm_changed" = true ]; then
    log_print "VM Tweaks"
fi

# 6. TỐI ƯU HÓA CGROUP / SCHEDTUNE (Top App Boost)
stune_dir=""
if [ -d "/sys/fs/cgroup/stune" ]; then
    stune_dir="/sys/fs/cgroup/stune"
elif [ -d "/sys/fs/cgroup/cpu/stune" ]; then
    stune_dir="/sys/fs/cgroup/cpu/stune"
fi

if [ -n "$stune_dir" ]; then
    top_app_logged=false
    if [ -f "$stune_dir/top-app/schedtune.boost" ]; then
        if write_val "15" "$stune_dir/top-app/schedtune.boost"; then
            log_print "====== Top App Tweaks ======"
            log_print "STUNE Foreground"
            top_app_logged=true
        fi
    fi
    if [ -f "$stune_dir/background/schedtune.boost" ]; then
        if write_val "-10" "$stune_dir/background/schedtune.boost"; then
            if [ "$top_app_logged" = false ]; then
                log_print "====== Top App Tweaks ======"
            fi
            log_print "STUNE Background"
        fi
    fi
fi

# 7. PHẢN HỒI CẢM ỨNG (CPU Input Boost Tweaks)
boost_changed=false
if write_val "1" "/sys/module/cpu_boost/parameters/sched_boost_on_input"; then boost_changed=true; fi
if write_val "50" "/sys/module/cpu_boost/parameters/input_boost_ms"; then boost_changed=true; fi
if write_val "50" "/sys/module/cpu_boost/parameters/input_boost_duration"; then boost_changed=true; fi

if [ "$boost_changed" = true ]; then
    log_print "Input Boost"
fi

# 8. TỐI ƯU HÓA ĐỌC/GHI ĐĨA (I/O Block Device Tweaks)
io_changed=false
for block_dev in /sys/block/*; do
    dev_name=$(basename "$block_dev")
    
    # Nếu là bộ nhớ nén ZRAM
    if echo "$dev_name" | grep -q "^zram"; then
        if write_val "32" "$block_dev/queue/read_ahead_kb"; then
            io_changed=true
        fi
    else
        # Nếu là các ổ bộ nhớ vật lý tiêu chuẩn (sda, sdb, mmcblk...)
        if [ -f "$block_dev/queue/scheduler" ]; then
            if grep -q "cfq" "$block_dev/queue/scheduler" 2>/dev/null; then
                write_val "cfq" "$block_dev/queue/scheduler"
                write_val "0" "$block_dev/queue/slice_idle"
                write_val "1" "$block_dev/queue/low_latency"
            fi
        fi
        # Thử áp dụng các mức bộ đệm đọc trước tối ưu nhất
        if write_val "64" "$block_dev/queue/read_ahead_kb" || \
           write_val "128" "$block_dev/queue/read_ahead_kb" || \
           write_val "256" "$block_dev/queue/read_ahead_kb"; then
            io_changed=true
        fi
        if write_val "64" "$block_dev/queue/nr_requests"; then
            io_changed=true
        fi
    fi
done

if [ "$io_changed" = true ]; then
    log_print "I/O Tweaks"
fi

# 9. TỐI ƯU FILE SYSTEM 
write_val "10" "/proc/sys/fs/lease-break-time"

# 10. ĐIỀU CHỈNH GOVERNOR SCHEDUTIL (Nếu kernel hỗ trợ)
for policy in /sys/devices/system/cpu/cpufreq/policy*; do
    if [ -d "$policy" ]; then
        governor=$(cat "$policy/scaling_governor" 2>/dev/null)
        if [ "$governor" = "schedutil" ]; then
            write_val "$dirty_ratio" "$policy/schedutil/hispeed_load"
            write_val "20000" "$policy/schedutil/rate_limit_us" 2>/dev/null
        fi
    fi
done

log_print "KernelEnhancer Optimization Completed Successfully"
